{
	"name": "@anterra/3p-plugin-dragon-dice",
	"version": "0.1.0",
	"description": "Dice Duel game plugin for TEX (third-party SDK)",
	"type": "module",
	"private": false,
	"license": "MIT",
	"scripts": {
		"build:svm": "bash scripts/anchor-build.sh",
		"codegen:svm": "node scripts/codegen-svm.mjs",
		"build:ts": "tsc --noEmit",
		"build": "tsup",
		"build:full": "pnpm build:svm && pnpm codegen:svm && pnpm build",
		"codegen": "pnpm codegen:svm",
		"test:svm": "anchor test",
		"test:ts": "vitest run",
		"test:e2e": "vitest run --project e2e",
		"test": "pnpm test:svm && pnpm test:ts && pnpm test:e2e",
		"clean": "rm -rf target/deploy target/idl generated/clients/svm",
		"clean:all": "pnpm clean && cargo clean"
	},
	"exports": {
		"./client": "./client/index.ts",
		"./server": {
			"types": "./server/index.ts",
			"default": "./dist/server/index.js"
		},
		"./shared": {
			"types": "./shared/index.ts",
			"default": "./dist/shared/index.js"
		},
		"./manifest": {
			"types": "./shared/manifest.ts",
			"default": "./dist/shared/manifest.js"
		},
		"./indexing-svm": {
			"types": "./shared/indexing-svm/index.ts",
			"default": "./dist/shared/indexing-svm/index.js"
		},
		"./svm": {
			"types": "./shared/svm/program.ts",
			"default": "./dist/shared/svm/program.js"
		}
	},
	"dependencies": {
		"@anterra/3p-plugin-sdk": "workspace:*",
		"@anterra/token-icons": "workspace:*",
		"@solana/kit": "catalog:"
	},
	"peerDependencies": {
		"@anterra/tex-ui-kit": "workspace:*",
		"@tanstack/react-query": "*",
		"react": ">=18",
		"viem": "*",
		"wagmi": "*",
		"zustand": "*"
	},
	"peerDependenciesMeta": {
		"@anterra/tex-ui-kit": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"viem": {
			"optional": true
		},
		"wagmi": {
			"optional": true
		},
		"@tanstack/react-query": {
			"optional": true
		},
		"zustand": {
			"optional": true
		}
	},
	"devDependencies": {
		"@codama/nodes-from-anchor": "~1.3.8",
		"@codama/renderers-js": "~1.7.0",
		"@repo/tsup-config": "workspace:*",
		"@types/react": "catalog:",
		"codama": "~1.5.0",
		"tsup": "catalog:",
		"typescript": "catalog:"
	},
	"files": [
		"client/",
		"dist/",
		"server/",
		"shared/",
		"generated/"
	],
	"imports": {
		"#generated/clients/svm/dice-duel": "./generated/clients/svm/dice-duel/index.ts",
		"#generated/clients/svm/dice-duel/pdas": "./generated/clients/svm/dice-duel/pdas.ts",
		"#generated/clients/svm/dice-duel/*": "./generated/clients/svm/dice-duel/*/index.ts"
	}
}
